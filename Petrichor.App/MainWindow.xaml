                                        Style="{StaticResource TransportButtonStyle}"
                                        ToolTip="Playlist Actions"
                                        Click="PlaylistActionsMenuButton_Click" />
                                <Popup x:Name="PlaylistActionsPopup"
                                       Grid.Column="2"
                                       PlacementTarget="{Binding ElementName=PlaylistActionsMenuButton}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade">
                                    <Border Background="#121A22"
                                            BorderBrush="#2C3E4F"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="6"
                                            Margin="0,8,0,0"
                                            MinWidth="198">
                                        <StackPanel>
                                            <Button Content="Save Current Queue"
                                                    Style="{StaticResource TransportButtonStyle}"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="0,0,0,6"
                                                    Padding="10,8"
                                                    Click="SaveCurrentQueueMenuItemButton_Click" />
                                            <Button Content="Add Current Track"
                                                    Style="{StaticResource TransportButtonStyle}"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="0,0,0,8"
                                                    Padding="10,8"
                                                    Click="AddCurrentTrackMenuItemButton_Click" />
                                            <Border Height="1" Background="#263746" Margin="4,0,4,8" />
                                            <Button Content="Import M3U..."
                                                    Style="{StaticResource TransportButtonStyle}"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="0,0,0,6"
                                                    Padding="10,8"
                                                    Click="ImportM3uMenuItemButton_Click" />
                                            <Button Content="Export Selected M3U"
                                                    Style="{StaticResource TransportButtonStyle}"
                                                    HorizontalAlignment="Stretch"
                                                    Padding="10,8"
                                                    Click="ExportM3uMenuItemButton_Click" />
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                            <TextBlock Grid.Row="1"
                                       Text="Create playlists, add tracks from your library or current playback, then double-click a playlist to restore it into the player."
                                       Foreground="#9DB0C4"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                        Margin="0,10,0,24" />
                            <Grid Grid.Row="2" MinHeight="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="320" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Background="#151B21" CornerRadius="12" Padding="18">
                                    <Grid MinHeight="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock x:Name="PlaylistsCenterSummaryTextBlock" Text="No playlists available" Foreground="#9DB0C4" Margin="0,0,0,12" />
                                        <ListBox x:Name="PlaylistsCenterListBox"
                                                 Grid.Row="1"
                                                 MinHeight="0"
                                                 VerticalAlignment="Stretch"
                                                 Style="{StaticResource PetrichorListBoxStyle}"
                                                 ItemContainerStyle="{StaticResource PetrichorListBoxItemStyle}"
                                                 ItemTemplate="{StaticResource PlaylistItemTemplate}"
                                                 SelectionChanged="PlaylistsListBox_SelectionChanged"
                                                 PreviewMouseWheel="PlaylistListBox_PreviewMouseWheel"
                                                 MouseDoubleClick="PlaylistsListBox_MouseDoubleClick"
                                                 >
                                        <ListBox.ContextMenu>
                                            <ContextMenu Style="{StaticResource PetrichorContextMenuStyle}">
                                                <MenuItem Header="Pin Playlist"
                                                          Style="{StaticResource PetrichorContextMenuItemStyle}"
                                                          CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Click="PinPlaylistMenuItem_Click" />
                                                    <Separator Style="{StaticResource PetrichorContextMenuSeparatorStyle}" />
                                                    <MenuItem Header="Rename Playlist"
                                                              Style="{StaticResource PetrichorContextMenuItemStyle}"
                                                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              Click="RenamePlaylistButton_Click" />
                                                    <MenuItem Header="Delete Playlist"
                                                              Style="{StaticResource PetrichorContextMenuItemStyle}"
                                                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              Click="DeletePlaylistButton_Click" />
                                                </ContextMenu>
                                            </ListBox.ContextMenu>
                                        </ListBox>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Background="#151B21" CornerRadius="12" Padding="18">
                                    <Grid MinHeight="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Playlist Tracks" Foreground="White" FontSize="18" FontWeight="SemiBold" />
                                            <TextBlock x:Name="PlaylistTracksSummaryTextBlock"
                                                       Text="Select a playlist to inspect its tracks"
                                                       Foreground="#9DB0C4"
                                                       Margin="0,8,0,0" />
                                        </StackPanel>

                                        <WrapPanel Grid.Row="1" Margin="0,14,0,12">
                                            <Button x:Name="AddTracksToPlaylistButton"
                                                    Content="Add Tracks..."
                                                    Style="{StaticResource TransportButtonStyle}"
                                                    Margin="0,0,10,10"
                                                    Padding="14,10"
                                                    Click="AddTracksToPlaylistButton_Click" />
                                            <Button Content="Add Current Track"
                                                    Style="{StaticResource TransportButtonStyle}"
                                                    Margin="0,0,10,10"
                                                    Padding="14,10"
                                                    Click="AddCurrentTrackToPlaylistButton_Click" />
                                            <Button x:Name="RemovePlaylistTrackButton"
                                                    Content="Remove Selected Track"
                                                    Style="{StaticResource TransportButtonStyle}"
                                                    Margin="0,0,10,10"
                                                    Padding="14,10"
                                                    Click="RemovePlaylistTrackButton_Click" />
                                            <TextBlock Text="Use Add Tracks to pull songs from Library. Drag tracks inside the playlist to reorder them."
                                                       Foreground="#8EA0B5"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,0,10" />
                                        </WrapPanel>

                                        <ListBox x:Name="PlaylistTracksListBox"
                                                 Grid.Row="2"
                                                 MinHeight="0"
                                                 VerticalAlignment="Stretch"
                                                 Style="{StaticResource PetrichorListBoxStyle}"
                                                 ItemContainerStyle="{StaticResource PetrichorListBoxItemStyle}"
                                                 ItemTemplate="{StaticResource TrackItemTemplate}"
                                                 AllowDrop="True"
                                                 PreviewMouseWheel="PlaylistListBox_PreviewMouseWheel"
                                                 PreviewMouseLeftButtonDown="PlaylistTracksListBox_PreviewMouseLeftButtonDown"
                                                 PreviewMouseMove="PlaylistTracksListBox_PreviewMouseMove"
                                                 DragOver="PlaylistTracksListBox_DragOver"
                                                 Drop="PlaylistTracksListBox_Drop"
                                                 MouseDoubleClick="PlaylistTracksListBox_MouseDoubleClick" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border x:Name="FoldersView" Background="#101418" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Folders" Foreground="White" FontSize="28" FontWeight="SemiBold" />
                            <TextBlock Text="Source folders that feed the library. Double-click a folder to start a queue from everything inside that location." Foreground="#9DB0C4" FontSize="14" TextWrapping="Wrap" Margin="0,10,0,24" />
                            <WrapPanel Margin="0,0,0,16">
                                <Button Content="Rescan All Folders"
                                        Style="{StaticResource SidebarActionButtonStyle}"
                                        Margin="0,0,10,10"
                                        Padding="14,10"
                                        Click="RescanAllFoldersButton_Click" />
                                <Button Content="Remove Selected Folder"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Margin="0,0,10,10"
                                        Padding="14,10"
                                        Click="RemoveSelectedFolderButton_Click" />
                            </WrapPanel>
                            <Border Background="#151B21" CornerRadius="12" Padding="18">
                                <StackPanel>
                                    <TextBlock x:Name="FoldersCenterSummaryTextBlock" Text="No folders added" Foreground="#9DB0C4" Margin="0,0,0,12" />
                            <ListBox x:Name="FoldersCenterListBox"
                                     Style="{StaticResource PetrichorListBoxStyle}"
                                     ItemContainerStyle="{StaticResource PetrichorListBoxItemStyle}"
                                     ItemTemplate="{StaticResource FolderItemTemplate}"
                                     SelectionChanged="FoldersListBox_SelectionChanged"
                                     MouseDoubleClick="FoldersListBox_MouseDoubleClick"
                                     MinHeight="480" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border x:Name="SettingsView" Background="#101418" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <TextBlock Text="Settings" Foreground="White" FontSize="28" FontWeight="SemiBold" />
                                <TextBlock Text="Control startup, library defaults and audio behavior for Petrichor on Windows."
                                           Foreground="#9DB0C4"
                                           FontSize="14"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,24" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Background="#151B21" CornerRadius="12" Padding="18">
                                        <StackPanel>
                                            <TextBlock Text="Behavior" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6" />
                                            <TextBlock Text="Startup and desktop lifecycle controls."
                                                       Foreground="#8EA0B5"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,14" />

                                            <Border Style="{StaticResource PetrichorSettingsCardStyle}">
                                                <StackPanel>
                                                    <CheckBox x:Name="StartMinimizedCheckBox"
                                                              Style="{StaticResource PetrichorSettingsCheckBoxStyle}"
                                                              Content="Start minimized to tray"
                                                              Checked="SettingsCheckBox_Changed"
                                                              Unchecked="SettingsCheckBox_Changed" />
                                                    <TextBlock Style="{StaticResource PetrichorSettingsHintTextStyle}"
                                                               Text="Launches Petrichor into tray mode so playback starts quietly in the background." />
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource PetrichorSettingsCardStyle}">
                                                <StackPanel>
                                                    <CheckBox x:Name="RestoreSessionCheckBox"
                                                              Style="{StaticResource PetrichorSettingsCheckBoxStyle}"
                                                              Content="Restore last playback session on launch"
                                                              Checked="SettingsCheckBox_Changed"
                                                              Unchecked="SettingsCheckBox_Changed" />
                                                    <TextBlock Style="{StaticResource PetrichorSettingsHintTextStyle}"
                                                               Text="Recovers queue, active track, repeat and shuffle state from the previous run." />
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource PetrichorSettingsCardStyle}">
                                                <StackPanel>
                                                    <CheckBox x:Name="AutoPlayAfterRestoreCheckBox"
                                                              Style="{StaticResource PetrichorSettingsCheckBoxStyle}"
                                                              Content="Auto-play after session restore"
                                                              Checked="SettingsCheckBox_Changed"
                                                              Unchecked="SettingsCheckBox_Changed" />
                                                    <TextBlock Style="{StaticResource PetrichorSettingsHintTextStyle}"
                                                               Text="Immediately resumes playback after restore instead of waiting for manual Play." />
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource PetrichorSettingsCardStyle}">
                                                <StackPanel>
                                                    <CheckBox x:Name="MinimizeToTrayOnCloseCheckBox"
                                                              Style="{StaticResource PetrichorSettingsCheckBoxStyle}"
                                                              Content="Minimize to tray when closing window"
                                                              Checked="SettingsCheckBox_Changed"
                                                              Unchecked="SettingsCheckBox_Changed" />
                                                    <TextBlock Style="{StaticResource PetrichorSettingsHintTextStyle}"
                                                               Text="Keeps app and playback alive when window close is used." />
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource PetrichorSettingsCardStyle}" Margin="0">
                                                <StackPanel>
                                                    <CheckBox x:Name="TrackNotificationsCheckBox"
                                                              Style="{StaticResource PetrichorSettingsCheckBoxStyle}"
                                                              Content="Show tray notifications when track changes"
                                                              Checked="SettingsCheckBox_Changed"
                                                              Unchecked="SettingsCheckBox_Changed" />
                                                    <TextBlock Style="{StaticResource PetrichorSettingsHintTextStyle}"
                                                               Text="Shows small tray popups for now-playing updates while you work." />
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource PetrichorSettingsCardStyle}" Margin="0,12,0,0">
                                                <StackPanel>
                                                    <CheckBox x:Name="AutoScanLibraryCheckBox"
                                                              Style="{StaticResource PetrichorSettingsCheckBoxStyle}"
                                                              Content="Auto-scan library folders for changes"
                                                              Checked="SettingsCheckBox_Changed"
                                                              Unchecked="SettingsCheckBox_Changed" />
                                                    <TextBlock Style="{StaticResource PetrichorSettingsHintTextStyle}"
                                                               Text="Uses Windows file watchers to import new tracks and clean removed ones in the background." />
                                                    <Button Content="Rescan Library Now"
                                                            Style="{StaticResource TransportButtonStyle}"
                                                            Margin="0,10,0,0"
                                                            Padding="12,8"
                                                            Click="RescanAllFoldersButton_Click" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Grid.Column="2">
                                        <Border Background="#151B21" CornerRadius="12" Padding="18" Margin="0,0,0,18">
                                            <StackPanel>
                                                <TextBlock Text="Interface and Library Defaults" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6" />
                                                <TextBlock Text="Choose where Petrichor opens and how large libraries are presented by default."
                                                           Foreground="#8EA0B5"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,14" />

                                                <TextBlock Text="Startup section" Foreground="#D8E3F0" FontSize="12" Margin="0,0,0,6" />
                                                <ComboBox x:Name="SettingsStartupSectionComboBox"
                                                          Style="{StaticResource PetrichorComboBoxStyle}"
                                                          Margin="0,0,0,10"
                                                          SelectionChanged="SettingsStartupSectionComboBox_SelectionChanged">
                                                    <ComboBoxItem Content="Home" Tag="Home" />
                                                    <ComboBoxItem Content="Library" Tag="Library" />
                                                    <ComboBoxItem Content="Playlists" Tag="Playlists" />
                                                    <ComboBoxItem Content="Folders" Tag="Folders" />
                                                    <ComboBoxItem Content="Settings" Tag="Settings" />
                                                </ComboBox>
                                                <TextBlock x:Name="SettingsStartupSectionHintTextBlock"
                                                           Foreground="#8EA0B5"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,12"
                                                           Text="Applies on next full app launch (use Exit from tray)." />

                                                <Border Style="{StaticResource PetrichorSettingsCardStyle}">
                                                    <StackPanel>
                                                        <CheckBox x:Name="RememberLastSectionCheckBox"
                                                                  Style="{StaticResource PetrichorSettingsCheckBoxStyle}"
                                                                  Content="Remember last opened section"
                                                                  Checked="SettingsCheckBox_Changed"
                                                                  Unchecked="SettingsCheckBox_Changed" />
                                                        <TextBlock Style="{StaticResource PetrichorSettingsHintTextStyle}"
                                                                   Text="When enabled, Petrichor reopens on the section you used last." />
                                                    </StackPanel>
                                                </Border>

                                                <Border Background="#121920"
                                                        BorderBrush="#24313D"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="12,10">
                                                    <TextBlock Text="Library sorting and filtering stay in the Library section only. Petrichor remembers your latest choices automatically."
                                                               Foreground="#8EA0B5"
                                                               FontSize="12"
                                                               TextWrapping="Wrap" />
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="#151B21" CornerRadius="12" Padding="18" Margin="0,0,0,18">
                                            <StackPanel>
                                                <TextBlock Text="Online Services" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6" />
                                                <TextBlock Text="Lyrics fallback and Last.fm scrobbling settings for Windows parity."
                                                           Foreground="#8EA0B5"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,14" />

                                                <Border Style="{StaticResource PetrichorSettingsCardStyle}">
                                                    <StackPanel>
                                                        <CheckBox x:Name="SettingsOnlineLyricsEnabledCheckBox"
                                                                  Style="{StaticResource PetrichorSettingsCheckBoxStyle}"
                                                                  Content="Fetch lyrics from internet when unavailable"
                                                                  Checked="SettingsCheckBox_Changed"
                                                                  Unchecked="SettingsCheckBox_Changed" />
                                                        <TextBlock Style="{StaticResource PetrichorSettingsHintTextStyle}"
                                                                   Text="Uses LRCLIB as fallback when no local .lrc/.srt or embedded lyrics are found." />
                                                    </StackPanel>
                                                </Border>

                                                <Border Style="{StaticResource PetrichorSettingsCardStyle}">
                                                    <StackPanel>
                                                        <CheckBox x:Name="SettingsLastFmScrobblingEnabledCheckBox"
                                                                  Style="{StaticResource PetrichorSettingsCheckBoxStyle}"
                                                                  Content="Enable Last.fm scrobbling"
                                                                  Checked="SettingsCheckBox_Changed"
                                                                  Unchecked="SettingsCheckBox_Changed" />
                                                        <TextBlock Style="{StaticResource PetrichorSettingsHintTextStyle}"
                                                                   Text="Sends now-playing and scrobbles when playback reaches Last.fm thresholds." />
                                                    </StackPanel>
                                                </Border>

                                                <Border Style="{StaticResource PetrichorSettingsCardStyle}">
                                                    <TextBlock x:Name="SettingsLastFmCredentialsHintTextBlock"
                                                               Style="{StaticResource PetrichorSettingsHintTextStyle}"
                                                               Text="Last.fm credentials are bundled with this Petrichor build (macOS-style setup)." />
                                                </Border>

                                                <TextBlock x:Name="SettingsLastFmStatusTextBlock"
                                                           Text="Not connected"
                                                           Foreground="#8EA0B5"
                                                           FontSize="12"
                                                           Margin="0,0,0,10" />

                                                <WrapPanel>
                                                    <Button x:Name="SettingsLastFmConnectButton"
                                                            Content="Connect Last.fm"
                                                            Style="{StaticResource SidebarActionButtonStyle}"
                                                            Padding="14,10"
                                                            Margin="0,0,10,10"
                                                            Click="ConnectLastFmButton_Click" />
                                                    <Button x:Name="SettingsLastFmDisconnectButton"
                                                            Content="Disconnect"
                                                            Style="{StaticResource TransportButtonStyle}"
                                                            Padding="14,10"
                                                            Margin="0,0,0,10"
                                                            Click="DisconnectLastFmButton_Click" />
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="#151B21" CornerRadius="12" Padding="18">
                                            <StackPanel>
                                                <TextBlock Text="Audio Defaults" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6" />
                                                <TextBlock Text="Quick toggles for EQ and DSP behavior. These controls reuse the live playback engine settings."
                                                           Foreground="#8EA0B5"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,14" />

                                                <Border Style="{StaticResource PetrichorSettingsCardStyle}">
                                                    <StackPanel>
                                                        <CheckBox x:Name="SettingsEqEnabledCheckBox"
                                                                  Style="{StaticResource PetrichorSettingsCheckBoxStyle}"
                                                                  Content="Enable Equalizer"
                                                                  Checked="SettingsEffectsCheckBox_Changed"
                                                                  Unchecked="SettingsEffectsCheckBox_Changed" />
                                                        <TextBlock Style="{StaticResource PetrichorSettingsHintTextStyle}"
                                                                   Text="Matches the EQ state used by the playback panel and preset system." />
                                                    </StackPanel>
                                                </Border>

                                                <Border Style="{StaticResource PetrichorSettingsCardStyle}">
                                                    <StackPanel>
                                                        <CheckBox x:Name="SettingsLoudnessEnabledCheckBox"
                                                                  Style="{StaticResource PetrichorSettingsCheckBoxStyle}"
                                                                  Content="Enable Loudness"
                                                                  Checked="SettingsEffectsCheckBox_Changed"
                                                                  Unchecked="SettingsEffectsCheckBox_Changed" />
                                                        <TextBlock Style="{StaticResource PetrichorSettingsHintTextStyle}"
                                                                   Text="Boosts perceived body at lower volume levels with safe limits." />
                                                    </StackPanel>
                                                </Border>

                                                <Border Style="{StaticResource PetrichorSettingsCardStyle}" Margin="0">
                                                    <StackPanel>
                                                        <CheckBox x:Name="SettingsReplayGainEnabledCheckBox"
                                                                  Style="{StaticResource PetrichorSettingsCheckBoxStyle}"
                                                                  Content="Enable ReplayGain"
                                                                  Checked="SettingsEffectsCheckBox_Changed"
                                                                  Unchecked="SettingsEffectsCheckBox_Changed" />
                                                        <TextBlock Style="{StaticResource PetrichorSettingsHintTextStyle}"
                                                                   Text="Normalizes playback loudness between tracks when ReplayGain tags are available." />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#12181E" BorderBrush="#202831" BorderThickness="1,0,0,0" Padding="18">
                <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="Library Sections" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14" />

                    <Border Background="#151B21" CornerRadius="12" Padding="14" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Folders" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock x:Name="FoldersSummaryTextBlock" Text="No folders added" Foreground="#9DB0C4" Margin="0,0,0,8" />
                            <ListBox x:Name="FoldersListBox"
                                     Style="{StaticResource PetrichorListBoxStyle}"
                                     ItemContainerStyle="{StaticResource PetrichorListBoxItemStyle}"
                                     ItemTemplate="{StaticResource FolderItemTemplate}"
                                     SelectionChanged="FoldersListBox_SelectionChanged"
                                     MouseDoubleClick="FoldersListBox_MouseDoubleClick"
                                     MinHeight="120" />
                        </StackPanel>
                    </Border>

                    <Border Background="#151B21" CornerRadius="12" Padding="14" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Playlists" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBlock x:Name="PlaylistsSummaryTextBlock" Text="No playlists available" Foreground="#9DB0C4" Margin="0,0,0,8" />
                                <ListBox x:Name="PlaylistsListBox"
                                         Style="{StaticResource PetrichorListBoxStyle}"
                                         ItemContainerStyle="{StaticResource PetrichorListBoxItemStyle}"
                                         ItemTemplate="{StaticResource PlaylistItemTemplate}"
                                         SelectionChanged="PlaylistsListBox_SelectionChanged"
                                         PreviewMouseWheel="PlaylistListBox_PreviewMouseWheel"
                                         MouseDoubleClick="PlaylistsListBox_MouseDoubleClick"
                                         MinHeight="120"
                                         MaxHeight="260">
                                    <ListBox.ContextMenu>
                                        <ContextMenu Style="{StaticResource PetrichorContextMenuStyle}">
                                        <MenuItem Header="Pin Playlist"
                                                  Style="{StaticResource PetrichorContextMenuItemStyle}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Click="PinPlaylistMenuItem_Click" />
                                        <Separator Style="{StaticResource PetrichorContextMenuSeparatorStyle}" />
                                        <MenuItem Header="Rename Playlist"
                                                  Style="{StaticResource PetrichorContextMenuItemStyle}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Click="RenamePlaylistButton_Click" />
                                        <MenuItem Header="Delete Playlist"
                                                  Style="{StaticResource PetrichorContextMenuItemStyle}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  Click="DeletePlaylistButton_Click" />
                                        </ContextMenu>
                                    </ListBox.ContextMenu>
                                </ListBox>
                        </StackPanel>
                    </Border>

                    <Border Background="#151B21" CornerRadius="12" Padding="14" Margin="0,0,0,14">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="Equalizer" Foreground="White" FontSize="16" FontWeight="SemiBold" DockPanel.Dock="Left" />
                                <TextBlock x:Name="EqualizerStatusTextBlock" Text="Unavailable" Foreground="#9DB0C4" FontSize="12" HorizontalAlignment="Right" />
                            </DockPanel>
                            <TextBlock Text="Shape the playback tone with a 10-band EQ. Changes apply to the active backend in real time." Foreground="#9DB0C4" TextWrapping="Wrap" Margin="0,0,0,12" />
                            <WrapPanel Margin="0,0,0,12">
                                <Button x:Name="EqualizerToggleButton"
                                        Content="EQ Off"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Margin="0,0,10,10"
                                        Padding="14,10"
                                        Click="EqualizerToggleButton_Click" />
                                <Button x:Name="EqualizerResetButton"
                                        Content="Reset EQ"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Margin="0,0,0,10"
                                        Padding="14,10"
                                        Click="EqualizerResetButton_Click" />
                            </WrapPanel>

                            <TextBlock Text="Presets" Foreground="#D8E3F0" FontSize="12" />
                            <Grid Margin="0,6,0,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ComboBox x:Name="EqualizerPresetComboBox"
                                          Style="{StaticResource PetrichorComboBoxStyle}"
                                          MinWidth="220"
                                          Padding="10,6"
                                          Background="#101418"
                                          Foreground="White"
                                          BorderBrush="#2E4253"
                                          SelectionChanged="EqualizerPresetComboBox_SelectionChanged"
                                          TextSearch.TextPath="Name">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#EAF2FB"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <WrapPanel Grid.Row="1" Margin="0,10,0,0">
                                    <Button
                                        Content="Save Preset"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Margin="0,0,8,0"
                                        Padding="12,8"
                                        Click="SaveEqualizerPresetButton_Click" />
                                    <Button
                                        Content="Import"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Margin="0,0,8,0"
                                        Padding="12,8"
                                        Click="ImportEqualizerPresetButton_Click" />
                                    <Button
                                        Content="Export"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Margin="0,0,8,0"
                                        Padding="12,8"
                                        Click="ExportEqualizerPresetButton_Click" />
                                    <Button x:Name="DeleteEqualizerPresetButton"
                                        Content="Delete"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Margin="0,4,0,0"
                                        Padding="12,8"
                                        Click="DeleteEqualizerPresetButton_Click" />
                                </WrapPanel>
                            </Grid>

                            <TextBlock Text="Preamp" Foreground="#D8E3F0" FontSize="12" />
                            <Grid Margin="0,6,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="EqualizerPreampSlider"
                                        Style="{StaticResource PetrichorSliderStyle}"
                                        Minimum="-12"
                                        Maximum="12"
                                        TickFrequency="0.5"
                                        ValueChanged="EqualizerControl_ValueChanged" />
                                <TextBlock x:Name="EqualizerPreampValueTextBlock"
                                           Grid.Column="1"
                                           Text="+0.0 dB"
                                           Foreground="#9DB0C4"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0" />
                            </Grid>

                            <TextBlock Text="Dynamics" Foreground="#D8E3F0" FontSize="12" />
                            <WrapPanel Margin="0,6,0,10">
                                <Button x:Name="LoudnessToggleButton"
                                        Content="Loudness Off"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Margin="0,0,10,10"
                                        Padding="12,8"
                                        Click="LoudnessToggleButton_Click" />
                                <Button x:Name="ReplayGainToggleButton"
                                        Content="ReplayGain Off"
                                        Style="{StaticResource TransportButtonStyle}"
                                        Margin="0,0,0,10"
                                        Padding="12,8"
                                        Click="ReplayGainToggleButton_Click" />
                            </WrapPanel>

                            <TextBlock Text="Loudness Gain" Foreground="#D8E3F0" FontSize="12" />
                            <Grid Margin="0,6,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="LoudnessGainSlider"
                                        Style="{StaticResource PetrichorSliderStyle}"
                                        Minimum="0"
                                        Maximum="6"
                                        TickFrequency="0.5"
                                        ValueChanged="DspControl_ValueChanged" />
                                <TextBlock x:Name="LoudnessGainValueTextBlock"
                                           Grid.Column="1"
                                           Text="+3.0 dB"
                                           Foreground="#9DB0C4"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0" />
                            </Grid>

                            <UniformGrid Columns="1" Rows="10">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="64" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="31 Hz" Foreground="#D8E3F0" VerticalAlignment="Center" />
                                    <Slider x:Name="EqualizerBand31Slider" Grid.Column="1" Style="{StaticResource PetrichorSliderStyle}" Minimum="-12" Maximum="12" TickFrequency="0.5" ValueChanged="EqualizerControl_ValueChanged" />
                                    <TextBlock x:Name="EqualizerBand31ValueTextBlock" Grid.Column="2" Text="+0.0 dB" Foreground="#9DB0C4" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="64" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="62 Hz" Foreground="#D8E3F0" VerticalAlignment="Center" />
                                    <Slider x:Name="EqualizerBand62Slider" Grid.Column="1" Style="{StaticResource PetrichorSliderStyle}" Minimum="-12" Maximum="12" TickFrequency="0.5" ValueChanged="EqualizerControl_ValueChanged" />
                                    <TextBlock x:Name="EqualizerBand62ValueTextBlock" Grid.Column="2" Text="+0.0 dB" Foreground="#9DB0C4" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="64" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="125 Hz" Foreground="#D8E3F0" VerticalAlignment="Center" />
                                    <Slider x:Name="EqualizerBand125Slider" Grid.Column="1" Style="{StaticResource PetrichorSliderStyle}" Minimum="-12" Maximum="12" TickFrequency="0.5" ValueChanged="EqualizerControl_ValueChanged" />
                                    <TextBlock x:Name="EqualizerBand125ValueTextBlock" Grid.Column="2" Text="+0.0 dB" Foreground="#9DB0C4" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="64" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="250 Hz" Foreground="#D8E3F0" VerticalAlignment="Center" />
                                    <Slider x:Name="EqualizerBand250Slider" Grid.Column="1" Style="{StaticResource PetrichorSliderStyle}" Minimum="-12" Maximum="12" TickFrequency="0.5" ValueChanged="EqualizerControl_ValueChanged" />
                                    <TextBlock x:Name="EqualizerBand250ValueTextBlock" Grid.Column="2" Text="+0.0 dB" Foreground="#9DB0C4" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="64" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="500 Hz" Foreground="#D8E3F0" VerticalAlignment="Center" />
                                    <Slider x:Name="EqualizerBand500Slider" Grid.Column="1" Style="{StaticResource PetrichorSliderStyle}" Minimum="-12" Maximum="12" TickFrequency="0.5" ValueChanged="EqualizerControl_ValueChanged" />
                                    <TextBlock x:Name="EqualizerBand500ValueTextBlock" Grid.Column="2" Text="+0.0 dB" Foreground="#9DB0C4" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="64" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="1 kHz" Foreground="#D8E3F0" VerticalAlignment="Center" />
                                    <Slider x:Name="EqualizerBand1000Slider" Grid.Column="1" Style="{StaticResource PetrichorSliderStyle}" Minimum="-12" Maximum="12" TickFrequency="0.5" ValueChanged="EqualizerControl_ValueChanged" />
                                    <TextBlock x:Name="EqualizerBand1000ValueTextBlock" Grid.Column="2" Text="+0.0 dB" Foreground="#9DB0C4" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="64" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="2 kHz" Foreground="#D8E3F0" VerticalAlignment="Center" />
                                    <Slider x:Name="EqualizerBand2000Slider" Grid.Column="1" Style="{StaticResource PetrichorSliderStyle}" Minimum="-12" Maximum="12" TickFrequency="0.5" ValueChanged="EqualizerControl_ValueChanged" />
                                    <TextBlock x:Name="EqualizerBand2000ValueTextBlock" Grid.Column="2" Text="+0.0 dB" Foreground="#9DB0C4" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="64" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="4 kHz" Foreground="#D8E3F0" VerticalAlignment="Center" />
                                    <Slider x:Name="EqualizerBand4000Slider" Grid.Column="1" Style="{StaticResource PetrichorSliderStyle}" Minimum="-12" Maximum="12" TickFrequency="0.5" ValueChanged="EqualizerControl_ValueChanged" />
                                    <TextBlock x:Name="EqualizerBand4000ValueTextBlock" Grid.Column="2" Text="+0.0 dB" Foreground="#9DB0C4" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="64" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="8 kHz" Foreground="#D8E3F0" VerticalAlignment="Center" />
                                    <Slider x:Name="EqualizerBand8000Slider" Grid.Column="1" Style="{StaticResource PetrichorSliderStyle}" Minimum="-12" Maximum="12" TickFrequency="0.5" ValueChanged="EqualizerControl_ValueChanged" />
                                    <TextBlock x:Name="EqualizerBand8000ValueTextBlock" Grid.Column="2" Text="+0.0 dB" Foreground="#9DB0C4" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="64" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="16 kHz" Foreground="#D8E3F0" VerticalAlignment="Center" />
                                    <Slider x:Name="EqualizerBand16000Slider" Grid.Column="1" Style="{StaticResource PetrichorSliderStyle}" Minimum="-12" Maximum="12" TickFrequency="0.5" ValueChanged="EqualizerControl_ValueChanged" />
                                    <TextBlock x:Name="EqualizerBand16000ValueTextBlock" Grid.Column="2" Text="+0.0 dB" Foreground="#9DB0C4" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Next and Previous already go through the same queue logic that now also drives folder and playlist playback." Foreground="#D8E3F0" TextWrapping="Wrap" Margin="0,0,0,10" />
                    <TextBlock Text="Session save and restore are routed through the Windows playback service layer." Foreground="#D8E3F0" TextWrapping="Wrap" />
                </StackPanel>
                </ScrollViewer>
            </Border>
            </Grid>

            <Border Grid.Row="2" Background="#151B21" BorderBrush="#202831" BorderThickness="0,1,0,0" Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PreviousButton" Style="{StaticResource TransportButtonStyle}" Content="Previous" Width="96" Height="40" Margin="0,0,10,0" Padding="14,0" Click="PreviousButton_Click" />
                        <Button x:Name="PlayPauseButton" Style="{StaticResource TransportButtonStyle}" Content="Play" Width="96" Height="40" Margin="0,0,10,0" Padding="14,0" Click="PlayPauseButton_Click" />
                        <Button x:Name="NextButton" Style="{StaticResource TransportButtonStyle}" Content="Next" Width="96" Height="40" Margin="0,0,10,0" Padding="14,0" Click="NextButton_Click" />
                        <Button x:Name="ShuffleButton" Style="{StaticResource TransportButtonStyle}" Content="Shuffle Off" Width="110" Height="40" Margin="0,0,10,0" Padding="14,0" Click="ShuffleButton_Click" />
                        <Button x:Name="RepeatButton" Style="{StaticResource TransportButtonStyle}" Content="Repeat Off" Width="110" Height="40" Padding="14,0" Click="RepeatButton_Click" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Volume" Foreground="#D8E3F0" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <Slider x:Name="VolumeSlider"
                                Style="{StaticResource PetrichorSliderStyle}"
                                Width="160"
                                Minimum="0"
                                Maximum="1"
                                Value="0.7"
                                ValueChanged="VolumeSlider_ValueChanged" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

